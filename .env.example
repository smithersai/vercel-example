DATABASE_URL=postgres://smithers:smithers@localhost:5432/vercel_example
TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret
# Leave blank for local fake outbox delivery; set in production for real Telegram sends.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_API_ROOT=https://api.telegram.org
# TELEGRAM_DELIVERY_MODE=fake
OPERATOR_SECRET=replace-with-operator-secret
CRON_SECRET=replace-with-cron-secret
E2E_TEST_ROUTES=0

# Optional local/dashboard settings.
# SMITHERS_GATEWAY_URL=http://127.0.0.1:7331
# NEXT_PUBLIC_SMITHERS_GATEWAY_URL=

# Optional route rate-limit overrides.
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_WEBHOOK_MAX=120
# RATE_LIMIT_TRIGGER_MAX=20
# RATE_LIMIT_CRON_MAX=10

# Optional queue drainer overrides.
# QUEUE_DRAIN_LIMIT=5
# QUEUE_LEASE_SECONDS=900
# QUEUE_MAX_ATTEMPTS=3
# QUEUE_BACKOFF_BASE_SECONDS=60
# QUEUE_BACKOFF_MAX_SECONDS=3600

# Optional local test settings.
# TEST_DATABASE_URL=postgres://smithers:smithers@localhost:5432/vercel_example
